class Empleado:
    def __init__(self, nombre, edad, salario, cargo):
        self.nombre = nombre
        self.edad = edad
        self.salario = salario
        self.cargo = cargo

    def obtener_nombre(self):
        return self.nombre

    def establecer_nombre(self, nombre):
        self.nombre = nombre

    def obtener_edad(self):
        return self.edad

    def establecer_edad(self, edad):
        self.edad = edad

    def obtener_salario(self):
        return self.salario

    def establecer_salario(self, salario):
        self.salario = salario

    def obtener_cargo(self):
        return self.cargo

    def establecer_cargo(self, cargo):
        self.cargo = cargo

    def salario_anual(self):
        return self.salario * 12


if __name__ == "__main__":
    empleado1 = Empleado("Ana", 30, 100000, "Obrero")

    print("Nombre:", empleado1.nombre)
    print("Edad:", empleado1.edad)
    print("Salario:", empleado1.salario)
    print("Cargo:", empleado1.cargo)
    print("Salario Anual:", empleado1.salario_anual())

    empleado1.establecer_nombre("Gmanuel")
    empleado1.establecer_edad(43)
    empleado1.establecer_salario(2600000)
    empleado1.establecer_cargo("Jefe de la Obra")

    print("\nDESPUES DE LA ACTUALIZACIÓN. . . . ")
    print("Nombre:", empleado1.nombre)
    print("Edad:", empleado1.edad)
    print("Salario:", empleado1.salario)
    print("Cargo:", empleado1.cargo)
    print("Salario Anual:", empleado1.salario_anual())
