class Tienda:
    def __init__(self, nombre):
        self.nombre = nombre
        self.productos = []
    
    def agregar_producto(self, producto):
        self.productos.append(producto)
    
    def eliminar_producto(self, producto):
        if producto in self.productos:
            self.productos.remove(producto)
    
    def listar_productos(self):
        return self.productos

if __name__ == "__main__":
    tienda1 = Tienda("COTO")
    tienda1.agregar_producto("Gaseosa")
    tienda1.agregar_producto("Galletas")
    tienda1.agregar_producto("Globos")
    tienda1.agregar_producto("Platos")

    print("Nombre:", tienda1.nombre)
    print("Lista de Productos:", tienda1.listar_productos())

    tienda1.eliminar_producto("Galletas")
    tienda1.eliminar_producto("Globos")
    tienda1.agregar_producto("Dulces")

    print("\nDESPUES DE ACTUALIZAR. . . .")
    print("Nombre:", tienda1.nombre)
    print("Lista de Productos:", tienda1.listar_productos())
